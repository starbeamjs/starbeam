{
  "name": "@starbeam/tags",
  "type": "module",
  "version": "0.0.0",
  "main": "index.ts",
  "types": "index.ts",
  "exports": {
    "default": "./index.ts"
  },
  "publishConfig": {
    "exports": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts"
  },
  "starbeam": {
    "inline": [
      "@starbeam/core-utils"
    ],
    "type": "library:public"
  },
  "scripts": {
    "build": "rollup -c",
    "prepack": "pnpm build",
    "test:lint": "eslint . --max-warnings 0",
    "test:types": "tsc -b"
  },
  "dependencies": {
    "@starbeam/interfaces": "workspace:^",
    "@starbeam/shared": "workspace:^",
    "inspect-utils": "^1.0.1"
  },
  "devDependencies": {
    "@starbeam/core-utils": "workspace:^",
    "@starbeam-dev/compile": "workspace:*",
    "rollup": "^4.60.1"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE.md"
  ],
  "release-plan": {
    "semverIncrementAs": {
      "major": "minor"
    }
  }
}
